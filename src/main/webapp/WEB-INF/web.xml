<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ReservationServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.ReservationServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StaffServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.StaffServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AddStaffServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.AddStaffServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GuestServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.GuestServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoomServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.RoomServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoomTypeServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.RoomTypeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardServley</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.DashboardServley</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.DashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ReservationServlet</servlet-name>
        <!--        <url-pattern>/reservation</url-pattern>-->
        <url-pattern>/manage-reservation</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StaffServlet</servlet-name>
        <url-pattern>/staff</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AddStaffServlet</servlet-name>
        <url-pattern>/AddStaffServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GuestServlet</servlet-name>
        <url-pattern>/guest</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RoomServlet</servlet-name>
        <url-pattern>/room</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RoomTypeServlet</servlet-name>
        <url-pattern>/roomType</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CheckAvailabilityAPI</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.api.CheckAvailabilityAPI</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ReservationAPI</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.api.ReservationAPI</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReservationAPI</servlet-name>
        <url-pattern>/api/reservations/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>RoomAvailabilityAPI</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.api.RoomAvailabilityAPI</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RoomAvailabilityAPI</servlet-name>
        <url-pattern>/api/rooms/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CheckAvailabilityAPI</servlet-name>
        <url-pattern>/api/checkAvailability</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>BillingAPI</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.api.BillingAPI</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BillingAPI</servlet-name>
        <url-pattern>/api/billing/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>DashboardAPI</servlet-name>
        <servlet-class>com.mycompany.ocean_view_resort.api.DashboardAPI</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardAPI</servlet-name>
        <url-pattern>/api/dashboard-stats/</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
